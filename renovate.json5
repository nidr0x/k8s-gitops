{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Madrid)",
    "helpers:pinGitHubActionDigests",
    "github>nidr0x/k8s-gitops//.renovate/labels.json5",
    "github>nidr0x/k8s-gitops//.renovate/customManagers.json5",
    "github>nidr0x/k8s-gitops//.renovate/automerge.json5",
    "github>nidr0x/k8s-gitops//.renovate/commitMessage.json5",
    "github>nidr0x/k8s-gitops//.renovate/groups.json5",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  branchTopic: "{{depName}}-{{newVersion}}",
  assignees: ["nidr0x"],
  reviewers: ["nidr0x"],
  argocd: {
    managerFilePatterns: ["/(^|/)argocd/.+\\.ya?ml$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
  ignorePaths: ["**/*.sops.*", "talos/clusterconfig/**", "talos/db/**"],
  packageRules: [
    {
      description: "Keep docker datasource updates separate",
      matchDatasources: ["docker"],
      groupName: null,
      groupSlug: null,
    },
    {
      description: "Disable broad automerge for non-GitHub-Actions updates",
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      matchManagers: [
        "argocd",
        "dockerfile",
        "helm-values",
        "kubernetes",
        "custom.regex",
      ],
      automerge: false,
    },
    {
      description: "Keep GitHub Actions automerge enabled",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
    },
    {
      matchPackageNames: ["homebridge/homebridge"],
      versioning: "regex:^(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})$",
    },
    {
      description: "Process Talos and Kubelet updates immediately",
      matchPackageNames: ["/siderolabs/.*/"],
      minimumReleaseAge: "0 days",
    },
  ],
  rangeStrategy: "auto",
  prHourlyLimit: 2,
  prConcurrentLimit: 20,
  separateMajorMinor: true,
  separateMultipleMajor: true,
}
